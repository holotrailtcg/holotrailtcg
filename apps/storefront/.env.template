# Holo Trail TCG - Next.js storefront environment
# Copy to apps/storefront/.env.local. Never commit the copied file.

# Local Medusa backend origin.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Local storefront origin used for metadata.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Holo Trail's default country/region. Code otherwise falls back to dk.
NEXT_PUBLIC_DEFAULT_REGION=gb

# Public Medusa Store API key from Admin > Settings > Publishable API Keys.
# Required by both next dev and next build. This is not a Stripe key.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Public Google reCAPTCHA v3 site key for the storefront hostname.
# Required to submit the newsletter form locally and by production builds.
# Unrelated development pages may render without it; submission fails closed.
# It is safe to expose.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Never put RECAPTCHA_SECRET_KEY, RESEND_API_KEY, database credentials,
# JWT/cookie secrets, or the newsletter rate-limit hash secret in this file.

# Server-only launch gate (never NEXT_PUBLIC_; never read in browser code).
# Only the exact strings "true" or "false" change the outcome. Any other
# value, including unset, fails closed and gates the store — the unfinished
# storefront must never be exposed by a missing or mistyped variable.
# "true"  = only the coming-soon/privacy/newsletter pages are reachable.
# "false" = the normal Medusa DTC storefront is reachable.
COMING_SOON_MODE=true

# Stripe is not used in the current stage. Leave blank.
NEXT_PUBLIC_STRIPE_KEY=

# Next.js sets NODE_ENV for dev/build/start. Do not set it manually here.
