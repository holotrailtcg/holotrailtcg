# ─────────────────────────────────────────────────────────────────────────────
# Holo Trail TCG - Next.js storefront environment template
#
# Copy this file to:
# apps/storefront/.env.local
#
# Fill in real development values locally.
# Never commit apps/storefront/.env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Local Medusa backend URL.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Local storefront URL.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default storefront country/region.
NEXT_PUBLIC_DEFAULT_REGION=gb

# Medusa publishable API key.
#
# Add this after the backend is running and the key has been created or
# retrieved from Medusa Admin.
#
# This is not a Stripe publishable key.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Public Google reCAPTCHA v3 site key for this storefront hostname.
# This value is safe to expose. Never put RECAPTCHA_SECRET_KEY in storefront env.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=replace-with-public-recaptcha-v3-site-key

# Stripe is not used during Stage 1.
# Leave empty.
NEXT_PUBLIC_STRIPE_KEY=

# Local Next.js environment.
NODE_ENV=development
