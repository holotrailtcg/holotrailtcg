# Holo Trail TCG - Medusa backend development environment
# Copy to apps/backend/.env. Never commit the copied file.
# Fill in real local values; do not reuse production secrets.

# Medusa HTTP configuration
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# Generate two different random values.
JWT_SECRET=
COOKIE_SECRET=

# Neon development database. Use the direct, non-pooler connection string
# with SSL enabled (normally ?sslmode=require).
DATABASE_URL=

# Human-readable only: current application code does not read DB_NAME.
DB_NAME=holotrail_medusa_dev

# Redis is not wired by medusa-config.ts. Leave unset.
# REDIS_URL=

# TCGdex integration layer. No provider credential is required.
TCGDEX_API_BASE_URL=https://api.tcgdex.net
TCGDEX_REQUEST_TIMEOUT_MS=5000
TCGDEX_MAX_RETRIES=3
TCGDEX_RETRY_BASE_DELAY_MS=250
TCGDEX_RETRY_MAX_DELAY_MS=4000
TCGDEX_MAX_RESPONSE_BYTES=1048576
# Test-only/local override for a local HTTP stub; never use in production.
# TCGDEX_ALLOW_INSECURE_LOCALHOST=false

# Newsletter confirmation token lifetime in whole minutes.
# Optional; defaults to 60. Valid range: 1-10080.
# NEWSLETTER_CONFIRMATION_TOKEN_TTL_MINUTES=60

# Newsletter rate limiting
# All three values are required by POST /store/newsletter/subscribe.
# They are currently validated when the route is called, not at backend boot.
NEWSLETTER_RATE_LIMIT_WINDOW_SECONDS=60
NEWSLETTER_RATE_LIMIT_MAX_REQUESTS=5
NEWSLETTER_RATE_LIMIT_HASH_SECRET=

# NEWSLETTER_RATE_LIMIT_WINDOW_SECONDS: integer 1-86400.
# NEWSLETTER_RATE_LIMIT_MAX_REQUESTS: integer 1-1000.
# NEWSLETTER_RATE_LIMIT_HASH_SECRET: unique random value, at least 32 characters.

# Trusted proxy configuration
# Keep disabled for ordinary local development. Only enable after confirming
# the production host's trusted proxy boundary and single-IP header.
NEWSLETTER_TRUST_PROXY=false
# NEWSLETTER_TRUSTED_IP_HEADER=

# Backend-only Google reCAPTCHA v3 configuration
# Never put RECAPTCHA_SECRET_KEY in the storefront or a NEXT_PUBLIC_ variable.
RECAPTCHA_SECRET_KEY=
NEWSLETTER_RECAPTCHA_MIN_SCORE=0.5

# Optional comma-separated hostname-only allowlist. Use lowercase hostnames;
# no scheme, path, port, or wildcard. Include localhost if enabled locally.
# Unset/blank disables hostname validation.
# NEWSLETTER_RECAPTCHA_ALLOWED_HOSTNAMES=localhost

# Optional token age in whole seconds; defaults to 120. Valid range: 1-300.
# NEWSLETTER_RECAPTCHA_MAX_TOKEN_AGE_SECONDS=120

# Backend-only Resend confirmation email configuration
# All four values are required by POST /store/newsletter/subscribe.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
PUBLIC_STOREFRONT_URL=http://localhost:8000

# RESEND_FROM_EMAIL accepts a bare address or Display Name <address> and must
# use a domain verified with Resend. RESEND_REPLY_TO_EMAIL must be bare.
# PUBLIC_STOREFRONT_URL must be a bare origin. Local HTTP is permitted only for
# localhost, 127.0.0.1, or ::1; production requires HTTPS.

# Optional resend cooldown in whole seconds; defaults to 300. Range: 0-86400.
# NEWSLETTER_CONFIRMATION_EMAIL_COOLDOWN_SECONDS=300

# Optional stale send-reservation window; defaults to 120. Range: 1-3600.
# NEWSLETTER_CONFIRMATION_EMAIL_STALE_RESERVATION_SECONDS=120

# Newsletter consent version is currently source-controlled in
# src/api/store/newsletter/shared/consent.ts; it is not an environment variable.

# Stage 4B.1 Cloudflare R2 card-image storage (backend-only; never storefront,
# never NEXT_PUBLIC_). Disabled by default: only the exact string "true"
# enables it, and local Medusa file behaviour is used until then.
R2_IMAGES_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_S3_ENDPOINT=
R2_PUBLIC_BASE_URL=

# When R2_IMAGES_ENABLED=true, every value above is required:
# - R2_ACCOUNT_ID: 32-character hex Cloudflare account ID.
# - R2_S3_ENDPOINT: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com, or the
#   jurisdiction-specific eu./fedramp. variant; account ID must match R2_ACCOUNT_ID.
# - R2_PUBLIC_BASE_URL: bare https origin (custom domain or R2.dev subdomain
#   configured for public access to the bucket).
# - R2_BUCKET_NAME: the listing-image bucket only.
#
# To obtain R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY:
#   1. Open the Cloudflare Dashboard.
#   2. Open R2 Object Storage.
#   3. Create or select the listing-image bucket.
#   4. Open "Manage R2 API tokens".
#   5. Create an "Object Read & Write" token restricted only to that bucket.
#   6. Copy the Access Key ID and Secret Access Key when Cloudflare shows them.
#   7. Save the values only in apps/backend/.env (never commit this file).
#   8. Never place them in apps/storefront/.env.local or any NEXT_PUBLIC_
#      variable, and never paste the secret into chat.
# Production values go in the future Medusa host's secret environment
# settings, not Vercel storefront settings.
