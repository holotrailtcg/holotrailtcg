# Holo Trail TCG - Medusa backend test environment
# Copy to apps/backend/.env.test. Never commit the copied file.
# Never point this file at development or production.

# Required for module and HTTP integration tests. The database name must
# contain "test" or the safety guard aborts. Unit tests need no database.
DATABASE_URL=

# Human-readable only: current application code does not read DB_NAME.
DB_NAME=holotrail_medusa_test

# Local test-only values. Never reuse production secrets.
JWT_SECRET=
COOKIE_SECRET=

STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# Redis is not wired by medusa-config.ts. Leave unset.
# REDIS_URL=

# TCGdex client tests inject fetch and do not call the real provider.
TCGDEX_API_BASE_URL=https://api.tcgdex.net
TCGDEX_REQUEST_TIMEOUT_MS=5000
TCGDEX_MAX_RETRIES=3
TCGDEX_RETRY_BASE_DELAY_MS=250
TCGDEX_RETRY_MAX_DELAY_MS=4000
TCGDEX_MAX_RESPONSE_BYTES=1048576

# Automated newsletter tests do not require real provider credentials:
# - unit tests pass explicit fake configuration and mock provider boundaries;
# - the HTTP harness supplies rate-limit/Resend overrides and injects fake
#   reCAPTCHA and email adapters;
# - the HTTP harness sets MEDUSA_ADMIN_DISABLE=true itself.
# Do not add real Google or Resend credentials to .env.test.

# Optional values for manually exercising config readers only:
# NEWSLETTER_CONFIRMATION_TOKEN_TTL_MINUTES=60
# NEWSLETTER_RATE_LIMIT_WINDOW_SECONDS=60
# NEWSLETTER_RATE_LIMIT_MAX_REQUESTS=5
# NEWSLETTER_RATE_LIMIT_HASH_SECRET=test-only-newsletter-rate-limit-hmac-secret-do-not-reuse
# NEWSLETTER_TRUST_PROXY=false
# NEWSLETTER_TRUSTED_IP_HEADER=
# RECAPTCHA_SECRET_KEY=test-only-recaptcha-secret-not-real
# NEWSLETTER_RECAPTCHA_MIN_SCORE=0.5
# NEWSLETTER_RECAPTCHA_ALLOWED_HOSTNAMES=localhost
# NEWSLETTER_RECAPTCHA_MAX_TOKEN_AGE_SECONDS=120
# RESEND_API_KEY=test-only-resend-api-key-not-real
# RESEND_FROM_EMAIL=Holo Trail TCG Test <hello@test.holotrailtcg.invalid>
# RESEND_REPLY_TO_EMAIL=support@test.holotrailtcg.invalid
# PUBLIC_STOREFRONT_URL=http://localhost:8000
# NEWSLETTER_CONFIRMATION_EMAIL_COOLDOWN_SECONDS=300
# NEWSLETTER_CONFIRMATION_EMAIL_STALE_RESERVATION_SECONDS=120

# Stage 4B.1 R2 image storage. Keep disabled for automated tests: no
# automated test may call real R2. Config-reader tests supply their own
# explicit fake environment objects instead of reading this file.
# If a test ever needs to exercise the enabled branch of resolveR2Config
# directly, do so with an explicit fake env object in the test itself
# (fake account ID/keys/bucket/endpoint/public URL) — never by setting real
# values here.
R2_IMAGES_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=holotrail-listing-images
R2_S3_ENDPOINT=
R2_PUBLIC_BASE_URL=https://images.holotrailtcg.co.uk

# Stage 4B.4 Slice 2 card-image cleanup dry-run. Leave unset or "true" for
# tests: the orphan-reconciliation job's own tests run against
# FakeR2ImageStorageClient and construct their own dryRun input explicitly,
# so this value is not exercised by automated tests either way.
# CARD_IMAGE_CLEANUP_DRY_RUN=true
