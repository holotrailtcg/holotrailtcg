# ─────────────────────────────────────────────────────────────────────────────
# Holo Trail TCG - Medusa backend test environment template
#
# Copy this file to:
# apps/backend/.env.test
#
# Never point this file at development or production.
# Never commit apps/backend/.env.test.
# ─────────────────────────────────────────────────────────────────────────────

# Separate Neon test database.
# The database name must clearly contain "test".
DATABASE_URL=

DB_NAME=holotrail_medusa_test

JWT_SECRET=
COOKIE_SECRET=

STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# Add only if a later approved test setup requires Redis.
# REDIS_URL=

# Newsletter rate limiting and reCAPTCHA (Stage 2C.4). The unit tests for
# these readers pass explicit fake env objects directly (never real
# process.env), so none of this is required for the test suite to pass.
# It is documented here only so a developer who wants to exercise the
# config readers against a real .env.test has clearly fake values to
# start from — never a real Google secret or a production-strength HMAC
# secret copied from elsewhere.
# NEWSLETTER_RATE_LIMIT_WINDOW_SECONDS=60
# NEWSLETTER_RATE_LIMIT_MAX_REQUESTS=5
# NEWSLETTER_RATE_LIMIT_HASH_SECRET=test-only-newsletter-rate-limit-hmac-secret-do-not-reuse
# RECAPTCHA_SECRET_KEY=test-only-recaptcha-secret-not-real
# NEWSLETTER_RECAPTCHA_MIN_SCORE=0.5
