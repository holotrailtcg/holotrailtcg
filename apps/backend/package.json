    "@medusajs/medusa": "2.17.2",
    "@medusajs/ui": "4.1.19",
    "@tanstack/react-query": "5.64.2",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.4",
    "resend": "^6.17.2",
    "sharp": "^0.34.5",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.17.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
