# Holo Trail TCG - combined environment reference
# This committed file contains placeholders only. It is not loaded in place of
# the app-local env files. Copy the relevant section to:
#   apps/backend/.env
#   apps/backend/.env.test
#   apps/storefront/.env.local

# Backend development: apps/backend/.env
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000
JWT_SECRET=
COOKIE_SECRET=
DATABASE_URL=
DB_NAME=holotrail_medusa_dev
# REDIS_URL=

# TCGdex integration layer (backend-only; no secret required).
TCGDEX_API_BASE_URL=https://api.tcgdex.net
TCGDEX_REQUEST_TIMEOUT_MS=5000
TCGDEX_MAX_RETRIES=3
TCGDEX_RETRY_BASE_DELAY_MS=250
TCGDEX_RETRY_MAX_DELAY_MS=4000
TCGDEX_MAX_RESPONSE_BYTES=1048576

# Optional confirmation token lifetime; default 60, range 1-10080.
# NEWSLETTER_CONFIRMATION_TOKEN_TTL_MINUTES=60

# Required by POST /store/newsletter/subscribe.
NEWSLETTER_RATE_LIMIT_WINDOW_SECONDS=60
NEWSLETTER_RATE_LIMIT_MAX_REQUESTS=5
NEWSLETTER_RATE_LIMIT_HASH_SECRET=

# Keep proxy trust disabled locally.
NEWSLETTER_TRUST_PROXY=false
# NEWSLETTER_TRUSTED_IP_HEADER=

# Backend-only Google reCAPTCHA configuration.
RECAPTCHA_SECRET_KEY=
NEWSLETTER_RECAPTCHA_MIN_SCORE=0.5
# NEWSLETTER_RECAPTCHA_ALLOWED_HOSTNAMES=localhost
# NEWSLETTER_RECAPTCHA_MAX_TOKEN_AGE_SECONDS=120

# Backend-only Resend and confirmation-link configuration.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
PUBLIC_STOREFRONT_URL=http://localhost:8000
# NEWSLETTER_CONFIRMATION_EMAIL_COOLDOWN_SECONDS=300
# NEWSLETTER_CONFIRMATION_EMAIL_STALE_RESERVATION_SECONDS=120

# Backend tests: apps/backend/.env.test
# Use a separate direct database whose name contains "test".
# DATABASE_URL=postgres://USER:PASSWORD@HOST/holotrail_medusa_test?sslmode=require
# Automated tests mock/supply newsletter providers; do not use real credentials.

# Storefront: apps/storefront/.env.local
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=gb
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Required for newsletter submission and production storefront builds. A
# missing local key does not block unrelated pages; submission fails closed.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_STRIPE_KEY=

# Backend secrets must never use NEXT_PUBLIC_ or be placed in the storefront.
# Next.js supplies NODE_ENV automatically.
